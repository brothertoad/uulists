---
title: uulists
---
{% extends "layouts/body.html.j2" %}
{% block content %}
<div class="block">
  <div class="columns is-centered">
    <div class="column button has-text-centered mx-6" onclick="populateBlock('tasks')">Tasks</div>
    <div class="column button has-text-centered mx-6" onclick="populateBlock('goals')">Goals</div>
    <div class="column button has-text-centered mx-6" onclick="populateBlock('audio')">Audio</div>
    <div class="column button has-text-centered mx-6" onclick="populateBlock('lilypond')">Lilypond</div>
  </div>
</div>
<div class="block">
  <div class="pre-line" id="scratchpad">
  </div>
</div>
<script type="text/javascript">
  const urlPrefix = "https://d1dems3vhrlf9r.cloudfront.net/blocks/"
  function populateBlock(blockName) {
    const req = new Request(urlPrefix + blockName);
    fetch(req).then(function(response) {
      response.text().then(function(text) {
        document.getElementById("scratchpad").innerHTML = text;
      })
    });

  }
</script>
{% endblock %}
